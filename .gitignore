# ============================================
# AmazoníaSearch — .gitignore
# Python + Node.js + Datos
# ============================================

# ──────────────────────────────────────────
# Python
# ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Entorno virtual
venv/
env/
.venv/
.env

# Distribución / Instalación
dist/
build/
*.egg-info/
*.egg
*.whl

# Tests / Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# MyPy
.mypy_cache/
dmypy.json

# ──────────────────────────────────────────
# Node.js / Frontend
# ──────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.cache/
.npm
*.tsbuildinfo

# ──────────────────────────────────────────
# Datos generados (DESCOMENTA si no quieres
# subir los datos al repositorio)
# ──────────────────────────────────────────
# backend/data/*.pkl
# backend/data/*.npy
# backend/data/*.bin
# backend/data/*.png

# ──────────────────────────────────────────
# IDEs y editores
# ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ──────────────────────────────────────────
# Sistema operativo
# ──────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ──────────────────────────────────────────
# Misceláneos
# ──────────────────────────────────────────
*.log
.cache/
*.bak
*.tmp
*.temp
